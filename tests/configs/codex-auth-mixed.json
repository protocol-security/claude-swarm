{
  "prompt": "unused",
  "driver": "codex-cli",
  "providers": {
    "openai_file": {
      "kind": "openai",
      "auth_file": "~/.codex/auth.json"
    },
    "openai_key": {
      "kind": "openai",
      "api_key": "$OPENAI_API_KEY"
    }
  },
  "pricing": {
    "gpt-5.4":       {"input": 2.50,  "output": 15.00, "cached": 0.25},
    "gpt-5.3-codex": {"input": 1.75,  "output": 14.00, "cached": 0.175}
  },
  "agents": [
    {
      "count": 1,
      "model": "gpt-5.4",
      "provider": "openai_file"
    },
    {
      "count": 1,
      "model": "gpt-5.3-codex",
      "provider": "openai_key"
    },
    {
      "count": 1,
      "model": "gpt-5.4",
      "provider": "openai_key"
    }
  ]
}
