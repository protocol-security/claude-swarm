{
  "prompt": "unused",
  "providers": {
    "anthropic_oauth": {
      "kind": "anthropic",
      "oauth_token": "$CLAUDE_CODE_OAUTH_TOKEN"
    },
    "kimi_key": {
      "kind": "kimi",
      "api_key": "$KIMI_API_KEY",
      "base_url": "https://api.kimi.com/coding/v1"
    }
  },
  "agents": [
    {
      "count": 1,
      "model": "claude-opus-4-6",
      "driver": "claude-code",
      "provider": "anthropic_oauth"
    },
    {
      "count": 1,
      "model": "kimi-for-coding",
      "driver": "kimi-cli",
      "provider": "kimi_key",
      "effort": "off"
    }
  ],
  "post_process": {
    "prompt": "unused-pp",
    "model": "kimi-for-coding",
    "driver": "kimi-cli",
    "provider": "kimi_key",
    "effort": "high"
  }
}
